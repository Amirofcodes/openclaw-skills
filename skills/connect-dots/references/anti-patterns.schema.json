{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "connect-dots anti-patterns store",
  "type": "object",
  "additionalProperties": false,
  "required": ["anti_patterns"],
  "properties": {
    "anti_patterns": {
      "type": "array",
      "items": { "$ref": "#/definitions/antiPattern" }
    }
  },
  "definitions": {
    "antiPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "pattern",
        "trigger_signals",
        "severity",
        "created_at",
        "updated_at",
        "source_runs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "pattern": { "type": "string", "minLength": 1 },
        "trigger_signals": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "created_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "source_runs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
