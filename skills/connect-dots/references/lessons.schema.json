{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "connect-dots lessons store",
  "type": "object",
  "additionalProperties": false,
  "required": ["lessons"],
  "properties": {
    "lessons": {
      "type": "array",
      "items": { "$ref": "#/definitions/lesson" }
    }
  },
  "definitions": {
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "scope",
        "pattern",
        "signals",
        "evidence_strength",
        "created_at",
        "updated_at",
        "source_runs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "pattern": { "type": "string", "minLength": 1 },
        "signals": { "type": "array", "items": { "type": "string" } },
        "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "applies_when": { "type": "array", "items": { "type": "string" } },
        "avoid_when": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "source_runs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
