{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "connect-dots pending decision candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "decision",
    "status",
    "revisit_trigger",
    "owner",
    "defer_signal",
    "source_evidence"
  ],
  "properties": {
    "topic": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["deferred", "queued"] },
    "revisit_trigger": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "defer_signal": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "context_links": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" },
    "source_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "lines", "quote"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "lines": { "type": "string", "pattern": "^L[0-9]+-L[0-9]+$" },
        "quote": { "type": "string", "minLength": 1 },
        "ts": { "type": "string" }
      }
    }
  }
}
